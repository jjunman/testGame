{
  "expo": {
    "name": "합주 매니지먼트",
    "slug": "band-management",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": [
      "**/*"
    ],
    "plugins": [
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "합주실 추천을 위해 현재 위치를 지도에 표시합니다."
        }
      ],
      "expo-notifications"
    ],
    "android": {
      "package": "com.anonymous.bandmanagement"
    }
  }
}
